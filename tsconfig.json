{
  "compilerOptions": {
    "target": "esnext",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "types": ["node"],
    "strictNullChecks": true,
    "allowJs": true
  },
  "include": ["src", "*.d.ts", "tests", "assets"],
  "exclude": ["node_modules", "dist", ".temp"]
}
